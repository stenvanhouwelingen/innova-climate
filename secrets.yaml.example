# Wi-Fi Credentials
wifi_ssid: "Your_WiFi_SSID"
wifi_password: "Your_WiFi_Password"

# ESPHome API Noise Encryption (Must be 32-byte Base64 key)
# You can generate this using: openssl rand -base64 32
api_key: "GENERATE_YOUR_OWN_BASE64_KEY_HERE"

# OTA Update Password
ota_password: "CHOOSE_A_SECURE_PASSWORD"

# Fallback AP Password
fallback_ap_password: "CHOOSE_A_SECURE_PASSWORD"
